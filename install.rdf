<?xml version="1.0" encoding="utf-8"?>
<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:em="http://www.mozilla.org/2004/em-rdf#">
	<Description about="urn:mozilla:install-manifest">
		<em:id>moonclocks@halvar666</em:id>
		<em:type>2</em:type>
		<em:bootstrap>true</em:bootstrap>
		<em:unpack>false</em:unpack>
		<em:version>1.0.0</em:version>
		<em:name>MoonClocks</em:name>
		<em:description>World clocks for Pale Moon and Epyrus. Based on the GPL-licensed FoxClocks 4.2.3 XUL codebase, with IANA tzdb 2026b and OpenStreetMap links.</em:description>
		<em:creator>Andy McDonald (original FoxClocks author); MoonClocks fork by Halvar666</em:creator>
		<em:iconURL>chrome://moonclocks/skin/icon32.png</em:iconURL>
		<em:icon64URL>chrome://moonclocks/skin/icon64.png</em:icon64URL>
		<em:optionsURL>chrome://moonclocks/content/foxclocks.xul</em:optionsURL>
		<em:multiprocessCompatible>true</em:multiprocessCompatible>

		<!-- Pale Moon -->
		<em:targetApplication>
			<Description>
				<em:id>{8de7fcbb-c55c-4fbe-bfc5-fc555c87dbc4}</em:id>
				<em:minVersion>27.0</em:minVersion>
				<em:maxVersion>34.*</em:maxVersion>
			</Description>
		</em:targetApplication>

		<!-- Epyrus -->
		<em:targetApplication>
			<Description>
				<em:id>{29877c1d-27df-4421-9a79-382c31470151}</em:id>
				<em:minVersion>2.0</em:minVersion>
				<em:maxVersion>2.*</em:maxVersion>
			</Description>
		</em:targetApplication>
		
		<em:translator>be: DRKA, Andrew O. Shadoura</em:translator>
